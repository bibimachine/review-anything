<Page x:Class="ReviewAnything.Views.CheckInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ReviewAnything.ViewModels"
      Title="CheckInPage">
    <Page.DataContext>
        <vm:CheckInViewModel />
    </Page.DataContext>
    <Grid Margin="32">
        <StackPanel HorizontalAlignment="Center" MaxWidth="400">
            <!-- 打卡状态 -->
            <Border Background="{Binding CheckedToday, Converter={StaticResource BoolToBrushConverter}}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding CheckedToday, Converter={StaticResource BoolToCheckInTextConverter}}"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Streak, StringFormat='🔥 连续打卡 {0} 天'}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0,8"/>
                </StackPanel>
            </Border>

            <Button Content="今日打卡" Padding="24,12" FontSize="16"
                    Command="{Binding CheckInCommand}"
                    Visibility="{Binding CheckedToday, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

            <!-- 月历 -->
            <Grid Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="打卡记录" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding CheckInDates}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#DBEAFE" CornerRadius="4" Padding="8,4" Margin="2">
                                <TextBlock Text="{Binding}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
