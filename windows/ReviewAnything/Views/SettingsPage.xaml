<Page x:Class="ReviewAnything.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ReviewAnything.ViewModels"
      Title="SettingsPage">
    <Page.DataContext>
        <vm:SettingsViewModel />
    </Page.DataContext>
    <ScrollViewer Margin="32">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="⚙️ 设置" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

            <TextBlock Text="模型配置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock Text="API Base URL" Foreground="#374151" Margin="0,4"/>
            <TextBox Text="{Binding ApiBaseUrl}" Padding="8" Margin="0,0,0,8"/>

            <TextBlock Text="API Key" Foreground="#374151" Margin="0,4"/>
            <TextBox Text="{Binding ApiKey}" Padding="8" Margin="0,0,0,8"/>

            <TextBlock Text="模型名称" Foreground="#374151" Margin="0,4"/>
            <TextBox Text="{Binding ModelName}" Padding="8" Margin="0,0,0,8"/>

            <Separator Margin="0,16"/>

            <TextBlock Text="复习设置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock Text="每日复习数量" Foreground="#374151" Margin="0,4"/>
            <TextBox Text="{Binding DailyCount}" Padding="8" Margin="0,0,0,8"/>

            <Button Content="保存设置" Padding="24,12" FontSize="16"
                    Command="{Binding SaveCommand}" Margin="0,16,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</Page>
