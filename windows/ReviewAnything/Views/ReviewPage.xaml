<Page x:Class="ReviewAnything.Views.ReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ReviewAnything.ViewModels"
      Title="ReviewPage">
    <Page.DataContext>
        <vm:ReviewViewModel />
    </Page.DataContext>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 空闲状态 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="📚" FontSize="64" HorizontalAlignment="Center"/>
            <TextBlock Text="准备开始复习" FontSize="24" FontWeight="Bold" Margin="0,16"/>
            <Button Content="开始复习" Padding="24,12" FontSize="16"
                    Command="{Binding StartCommand}"/>
        </StackPanel>

        <!-- 复习中 -->
        <Grid Grid.Row="1" Visibility="{Binding IsIdle, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 进度 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ProgressText}" FontSize="14" Foreground="#6B7280"/>
                <ProgressBar Grid.Column="1" Width="200" Height="4"
                             Value="{Binding CurrentIndex}" Maximum="{Binding Items.Count}"/>
            </Grid>

            <!-- 问题卡片 -->
            <Border Grid.Row="2" Background="#EFF6FF" CornerRadius="12" Padding="32" Margin="0,16">
                <TextBlock Text="{Binding CurrentItem.Question}"
                           FontSize="20" TextWrapping="Wrap"
                           TextAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 答案卡片 -->
            <Border Grid.Row="3" Background="#ECFDF5" CornerRadius="12" Padding="24" Margin="0,8"
                    Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding CurrentItem.Answer}"
                           FontSize="16" TextWrapping="Wrap"/>
            </Border>

            <!-- 按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                <Button Content="查看答案" Padding="32,12" FontSize="16"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        Command="{Binding ShowAnswerCommand}"/>
                <Button Content="忘记了" Padding="32,12" FontSize="16" Margin="0,0,8,0"
                        Background="#FEE2E2" Foreground="#DC2626" BorderBrush="#FECACA"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding ForgetCommand}"/>
                <Button Content="记住了" Padding="32,12" FontSize="16"
                        Background="#DBEAFE" Foreground="#2563EB" BorderBrush="#BFDBFE"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding RememberCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
