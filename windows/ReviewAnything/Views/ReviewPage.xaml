<Page x:Class="ReviewAnything.Views.ReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ReviewAnything.ViewModels"
      Title="ReviewPage">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 打卡状态 -->
        <Border Grid.Row="0" CornerRadius="12" Padding="16" Margin="0,0,0,16"
                Background="{Binding CheckedToday, Converter={StaticResource BoolToBrushConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding CheckedToday, Converter={StaticResource BoolToCheckInTextConverter}}"
                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Streak, StringFormat=' 🔥 连续打卡 {0} 天'}"
                           FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 空状态：无笔记 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="📭" FontSize="64" HorizontalAlignment="Center"/>
            <TextBlock Text="暂无复习内容" FontSize="24" FontWeight="Bold" Margin="0,16" HorizontalAlignment="Center"/>
            <TextBlock Text="请先上传笔记，系统会为你生成复习卡片" FontSize="14" Foreground="#6B7280"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" Margin="0,0,0,16"/>
            <Button Content="刷新试试" Padding="24,12" FontSize="16"
                    Command="{Binding StartCommand}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 空闲状态：有笔记但尚未开始 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="📚" FontSize="64" HorizontalAlignment="Center"/>
            <TextBlock Text="准备开始复习" FontSize="24" FontWeight="Bold" Margin="0,16" HorizontalAlignment="Center"/>
            <TextBlock Text="点击开始复习，系统会按间隔重复算法为你调度" FontSize="14" Foreground="#6B7280"
                       Margin="0,0,0,16" HorizontalAlignment="Center"/>
            <Button Content="开始复习" Padding="24,12" FontSize="16"
                    Command="{Binding StartCommand}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 复习中 / 完成 -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsIdle, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 进度 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ProgressText}" FontSize="14" Foreground="#6B7280"/>
                <ProgressBar Grid.Column="1" Width="200" Height="4"
                             Value="{Binding CurrentIndex}" Maximum="{Binding Items.Count}"/>
            </Grid>

            <!-- 完成状态 -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsFinished, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="🎉" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="今日复习完成！" FontSize="24" FontWeight="Bold" Margin="0,16" HorizontalAlignment="Center"/>
                <TextBlock Text="已自动打卡 ✅" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <Button Content="再来一组" Padding="24,12" FontSize="16"
                        Command="{Binding RestartCommand}" HorizontalAlignment="Center" Margin="0,16"/>
            </StackPanel>

            <!-- 问题卡片 -->
            <Border Grid.Row="2" Background="#EFF6FF" CornerRadius="12" Padding="32" Margin="0,16"
                    Visibility="{Binding IsFinished, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding CurrentItem.Question}"
                           FontSize="20" TextWrapping="Wrap"
                           TextAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 答案卡片 -->
            <Border Grid.Row="3" Background="#ECFDF5" CornerRadius="12" Padding="24" Margin="0,8"
                    Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding CurrentItem.Answer}"
                           FontSize="16" TextWrapping="Wrap"/>
            </Border>

            <!-- 按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                <Button Content="查看答案" Padding="32,12" FontSize="16"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        Command="{Binding ShowAnswerCommand}"/>
                <Button Content="忘记了" Padding="32,12" FontSize="16" Margin="0,0,8,0"
                        Background="#FEE2E2" Foreground="#DC2626" BorderBrush="#FECACA"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding ForgetCommand}"/>
                <Button Content="记住了" Padding="32,12" FontSize="16"
                        Background="#DBEAFE" Foreground="#2563EB" BorderBrush="#BFDBFE"
                        Visibility="{Binding ShowAnswer, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding RememberCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
